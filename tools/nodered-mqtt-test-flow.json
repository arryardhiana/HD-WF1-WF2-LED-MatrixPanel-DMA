  {
    "id": "fn-random-event",
    "type": "function",
    "z": "tab-parking-test",
    "name": "Random Event Generator",
    "func": "const prefixes = ['B', 'D', 'F', 'E', 'Z', 'H', 'G', 'L', 'W', 'N', 'P', 'S', 'T', 'R', 'K'];\nconst suffixes = ['ABC', 'BCD', 'CDE', 'DEF', 'EFG', 'XYZ', 'AAA', 'BBB', 'RFQ', 'ZZZ', 'ASD', 'QWE'];\nconst prefix = prefixes[Math.floor(Math.random() * prefixes.length)];\nconst number = Math.floor(Math.random() * 8999) + 1000;\nconst suffix = suffixes[Math.floor(Math.random() * suffixes.length)];\nconst plate  = prefix + ' ' + number + ' ' + suffix;\n\nconst statuses = ['granted', 'denied', 'scanning', 'idle'];\nconst weights  = [4, 3, 2, 1];\nconst totalW   = weights.reduce((a, b) => a + b, 0);\nlet rand = Math.random() * totalW, statusIdx = 0;\nfor (let i = 0; i < weights.length; i++) {\n    rand -= weights[i];\n    if (rand <= 0) { statusIdx = i; break; }\n}\nconst status = statuses[statusIdx];\n\nconst anprOptions = ['detected', 'not_detected'];\nconst anpr_status = anprOptions[Math.floor(Math.random() * anprOptions.length)];\n\nconst payload = {\n    status:      status,\n    plate:       (status === 'idle') ? '' : plate,\n    anpr_status: anpr_status,\n    gate_name:   'Gate A',\n    timestamp:   Math.floor(Date.now() / 1000)\n};\n\nmsg.topic   = 'parking/gate-01/event';\nmsg.payload = JSON.stringify(payload);\nnode.warn('[event] status=' + status + ' plate=' + payload.plate + ' anpr=' + anpr_status);\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 360,
    "y": 100,
    "wires": [["mqtt-out-event", "debug-event"]]
  },
