    "func": "const texts  = ['Selamat Datang', 'Hati-hati di Jalan', 'Terima Kasih', 'Selamat Bekerja', 'Semangat!', 'Have a Nice Day'];\nconst colors = ['white', 'yellow', 'cyan'];\nconst text   = texts[Math.floor(Math.random() * texts.length)];\nconst color  = colors[Math.floor(Math.random() * colors.length)];\nconst scroll = text.length > 10;\nmsg.topic   = 'parking/gate-01/greeting';\nmsg.payload = JSON.stringify({ text: text, scroll: scroll, color: color });\nreturn msg;",
